#!/usr/bin/env bash
# Parallel peel overnight: precompute w16 caches, then train all 8 on GPUs 0-7.
set -u

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT"

PYTHON_BIN="${PYTHON:-python}"
export HF_HUB_OFFLINE="${HF_HUB_OFFLINE:-1}"

STAMP="$(date +%Y%m%d_%H%M%S)"
LOG_DIR="${ROOT}/outputs/peel/overnight_parallel_${STAMP}"
mkdir -p "$LOG_DIR"
MASTER_LOG="${LOG_DIR}/overnight.log"
PID_FILE="${LOG_DIR}/pids.txt"
SUMMARY="${LOG_DIR}/summary.txt"

log() {
  local msg="[$(date '+%F %T')] $*"
  echo "$msg" | tee -a "$MASTER_LOG"
}

TRAIN_JOBS=(
  "0:01:configs/train/peel/01_peel_all_unet_h8_c32_v2_abs.yaml"
  "1:03:configs/train/peel/03_peel_all_dit_h8_c32_v2_abs.yaml"
  "2:05:configs/train/peel/05_peel_new_unet_h8_c32_v2_abs.yaml"
  "3:07:configs/train/peel/07_peel_new_dit_h8_c32_v2_abs.yaml"
  "4:02:configs/train/peel/02_peel_all_unet_h16_c64_v2_rel.yaml"
  "5:04:configs/train/peel/04_peel_all_dit_h16_c64_v3_rel.yaml"
  "6:06:configs/train/peel/06_peel_new_unet_h16_c64_v2_rel.yaml"
  "7:08:configs/train/peel/08_peel_new_dit_h16_c64_v3_rel.yaml"
)

PRECOMPUTE_CONFIGS=(
  "configs/train/peel/02_peel_all_unet_h16_c64_v2_rel.yaml"
  "configs/train/peel/06_peel_new_unet_h16_c64_v2_rel.yaml"
)

log "==== peel parallel overnight start ===="
log "LOG_DIR=$LOG_DIR"
log "epochs should be 256 in each peel yaml"

# 1) sequential precompute (camera RAM ~100-250GB each)
log "---- precompute w16/ah64 (sequential) ----"
for cfg in "${PRECOMPUTE_CONFIGS[@]}"; do
  name="$(basename "$cfg" .yaml)"
  log_file="${LOG_DIR}/precompute_${name}.log"
  log "PRECOMPUTE $cfg"
  if CUDA_VISIBLE_DEVICES=0 "$PYTHON_BIN" tools/precompute_policy_latents.py --config "$cfg" \
      >"$log_file" 2>&1; then
    log "OK precompute $name"
    echo "PASS precompute $name" >> "$SUMMARY"
  else
    log "FAIL precompute $name — see $log_file"
    echo "FAIL precompute $name" >> "$SUMMARY"
    log "Aborting: w16 trains need this cache"
    exit 1
  fi
done

# 2) launch 8 trains in parallel
log "---- launch 8 parallel trains ----"
declare -a PIDS=()
declare -a NAMES=()

for job in "${TRAIN_JOBS[@]}"; do
  IFS=':' read -r gpu id cfg <<< "$job"
  name="$(basename "$cfg" .yaml)"
  log_file="${LOG_DIR}/train_${name}.log"
  NAMES+=("$id:$name")
  log "TRAIN [$id] GPU=$gpu $cfg"
  (
    export CUDA_VISIBLE_DEVICES="$gpu"
    ./scripts/train.sh --config "$cfg" --gpus "$gpu" >"$log_file" 2>&1
    ec=$?
    if [[ $ec -eq 0 ]]; then
      echo "PASS train $id $name" >> "$SUMMARY"
      echo "[$(date '+%F %T')] OK train [$id] $name" >> "$MASTER_LOG"
    else
      echo "FAIL train $id $name exit=$ec" >> "$SUMMARY"
      echo "[$(date '+%F %T')] FAIL train [$id] $name exit=$ec" >> "$MASTER_LOG"
    fi
    exit $ec
  ) &
  pid=$!
  PIDS+=("$pid")
  echo "gpu=$gpu id=$id pid=$pid config=$cfg" >> "$PID_FILE"
done

log "all train PIDs: ${PIDS[*]}"
log "pid file: $PID_FILE"

FAILED=0
PASSED=0
for i in "${!PIDS[@]}"; do
  pid="${PIDS[$i]}"
  name="${NAMES[$i]}"
  if wait "$pid"; then
    PASSED=$((PASSED + 1))
    log "joined OK $name pid=$pid"
  else
    FAILED=$((FAILED + 1))
    log "joined FAIL $name pid=$pid"
  fi
done

log "==== peel parallel overnight done ===="
log "passed=$PASSED failed=$FAILED"
echo "passed=$PASSED failed=$FAILED" >> "$SUMMARY"
log "summary: $SUMMARY"

[[ "$FAILED" -eq 0 ]]
